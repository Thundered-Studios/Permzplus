      "require": "./dist/adapters/redis.cjs"
    },
    "./adapters/typeorm": {
      "types": "./dist/adapters/typeorm.d.ts",
      "import": "./dist/adapters/typeorm.js",
      "require": "./dist/adapters/typeorm.cjs"
    },
    "./adapters/knex": {
      "types": "./dist/adapters/knex.d.ts",
      "import": "./dist/adapters/knex.js",
      "require": "./dist/adapters/knex.cjs"
    },
    "./adapters/sequelize": {
      "types": "./dist/adapters/sequelize.d.ts",
      "import": "./dist/adapters/sequelize.js",
      "require": "./dist/adapters/sequelize.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js",
      "require": "./dist/query.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./validator": {
      "types": "./dist/validator.d.ts",
      "import": "./dist/validator.js",
      "require": "./dist/validator.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/speed-test.ts",
    "bench:compare": "tsx bench/benchmark.ts",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@casl/ability": "^6.8.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "accesscontrol": "^2.2.1",
    "drizzle-orm": "^0.45.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "mitata": "^1.0.0",
    "prettier": "^3.2.5",
    "react": "^19.2.4",
    "tsup": "^8.0.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0",
    "vue": "^3.5.31"
  },
